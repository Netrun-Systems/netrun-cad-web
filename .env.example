# Google Drive integration credentials
# Get these from Google Cloud Console > APIs & Services > Credentials
# OAuth 2.0 Client ID (Web application type)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# API Key (restricted to cad.netrunsystems.com + Drive Picker API)
VITE_GOOGLE_API_KEY=your-api-key

# Backend API endpoints (used by src/services/api.ts and src/contexts/WebSocketContext.tsx)
# In dev these default to localhost; in production they're injected at build time by Cloud Build.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Survai cloud scan integration (used by src/services/survai.ts)
# Leave VITE_SURVAI_TOKEN unset for unauthenticated local dev.
VITE_SURVAI_API_URL=http://localhost:8000
# VITE_SURVAI_TOKEN=
